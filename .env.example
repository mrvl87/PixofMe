# PIXFORME environment placeholders
# Copy this file to .env.local and fill real values. Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_GUARD_ENABLED=false

# Supabase public browser/server auth client
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
# Optional legacy fallback if you still use anon naming
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase server-only keys. Never expose as NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
SUPABASE_STORAGE_BUCKET=pixforme-photos

# Maps
# Satellite basemap uses Esri World Imagery. Geocoding/reverse geocoding uses Geoapify.
NEXT_PUBLIC_MAP_PROVIDER=esri-world-imagery
NEXT_PUBLIC_GEOCODING_PROVIDER=geoapify
NEXT_PUBLIC_GEOAPIFY_API_KEY=YOUR_BROWSER_RESTRICTED_GEOAPIFY_KEY
GEOAPIFY_API_KEY=YOUR_SERVER_RESTRICTED_GEOAPIFY_KEY
MAPS_DEFAULT_LANGUAGE=id
MAPS_DEFAULT_COUNTRY_CODE=id

# Midtrans sandbox / production
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_CLIENT_KEY=YOUR_MIDTRANS_CLIENT_KEY
MIDTRANS_SERVER_KEY=YOUR_MIDTRANS_SERVER_KEY
MIDTRANS_NOTIFICATION_SECRET=YOUR_MIDTRANS_NOTIFICATION_SECRET

# AI provider gateway
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_FREE_TIER_MONTHLY_CREDITS=0
AI_CREDIT_SKU=ai_starter